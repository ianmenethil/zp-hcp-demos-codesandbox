# ── Zenith Payments — sandbox credentials (matches valtown/express env names) ──
# Copy to .env and fill in your UAT values. Never commit .env to version control.
ZP_API_KEY=YOUR_API_KEY
ZP_MERCHANT_CODE=YOUR_MERCHANT_CODE
ZP_USERNAME=YOUR_USERNAME
ZP_PASSWORD=YOUR_PASSWORD

# ── Exchange token secret ──
# Any random string — used to sign single-use init→exchange tokens (HMAC-SHA256).
EXCHANGE_TOKEN_SECRET=CHANGE_ME_TO_A_RANDOM_32_BYTE_HEX_STRING

# ── Cloudflare Turnstile ──
# Use the test secret key for local development (always passes).
# Production: get your site key + secret from https://dash.cloudflare.com/
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# ── Server config ──
PORT=3000
